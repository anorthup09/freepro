generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Auth ────────────────────────────────────────────────────────────────────

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String
  role      UserRole @default(CREW)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("users")
}

enum UserRole {
  ADMIN
  PRODUCER
  CREW
  CLIENT
}

// ─── Projects ────────────────────────────────────────────────────────────────

model Project {
  id          String        @id @default(cuid())
  code        String        @unique       // e.g. "02.CGS00626"
  title       String
  subtitle    String?
  client      String
  city        String
  state       String
  startDate   DateTime
  endDate     DateTime
  status      ProjectStatus @default(PLANNING)
  notes       String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  locations       Location[]
  techSpecs       TechSpec?
  clientContacts  ClientContact[]
  keyTalent       KeyTalent[]
  crewAssignments CrewAssignment[]
  shootDays       ShootDay[]
  deliverables    Deliverable[]
  hotelBlocks     HotelBlock[]
  flights         Flight[]
  driveGroups     DriveGroup[]

  @@map("projects")
}

enum ProjectStatus {
  PLANNING
  ACTIVE
  WRAPPED
  DELIVERED
  ARCHIVED
}

// ─── Locations ───────────────────────────────────────────────────────────────

model Location {
  id          String       @id @default(cuid())
  projectId   String
  name        String
  address     String
  type        LocationType
  emoji       String?
  notes       String?

  project     Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  events      ScheduleEvent[]

  @@map("locations")
}

enum LocationType {
  PRIMARY_VENUE
  CREW_HOTEL
  SECONDARY
  AIRPORT
  OTHER
}

// ─── Tech Specs ──────────────────────────────────────────────────────────────

model TechSpec {
  id            String  @id @default(cuid())
  projectId     String  @unique
  aspectRatio   String?   // "2.39:1"
  resolution    String?   // "3672 × 1536"
  quality       String?   // "4K"
  cameras       String?   // "A, B, C + Drone"
  execProducer  String?
  onSiteEditor  String?
  notes         String?

  project       Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@map("tech_specs")
}

// ─── Client Contacts ─────────────────────────────────────────────────────────

model ClientContact {
  id        String  @id @default(cuid())
  projectId String
  name      String
  title     String
  email     String?
  phone     String?

  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@map("client_contacts")
}

// ─── Key Talent ──────────────────────────────────────────────────────────────

model KeyTalent {
  id        String  @id @default(cuid())
  projectId String
  name      String
  role      String
  notes     String?

  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@map("key_talent")
}

// ─── Crew ─────────────────────────────────────────────────────────────────────

model Position {
  id          String   @id @default(cuid())
  name        String   @unique   // "Director", "DP/Cam Op", "Audio Engineer" …
  sortOrder   Int      @default(0)
  isActive    Boolean  @default(true)

  assignments CrewAssignment[]

  @@map("positions")
}

model CrewMember {
  id          String   @id @default(cuid())
  name        String
  email       String?
  phone       String?
  company     String?
  initials    String?
  avatarColor String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  assignments CrewAssignment[]
  eventTags   EventCrewTag[]
  hotelGuests HotelGuest[]
  flights     Flight[]
  driveGroups DriveGroupMember[]

  @@map("crew_members")
}

model CrewAssignment {
  id           String   @id @default(cuid())
  projectId    String
  positionId   String
  crewMemberId String?  // null = position exists on project but unassigned
  slotNumber   Int      @default(1)  // 1 = only/first, 2 = second Audio Engineer, etc.
  notes        String?

  project      Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  position     Position       @relation(fields: [positionId], references: [id])
  crewMember   CrewMember?    @relation(fields: [crewMemberId], references: [id])
  dayCalls     CrewDayCall[]

  @@unique([projectId, positionId, slotNumber])
  @@map("crew_assignments")
}

// Per-day call time for each crew assignment
model CrewDayCall {
  id               String         @id @default(cuid())
  crewAssignmentId String
  shootDayId       String
  callTime         String?        // "7:30 AM"
  wrapTime         String?        // "10:00 PM"
  locationNote     String?        // "KCCC Main Entrance" — freetext, not FK
  notes            String?

  crewAssignment   CrewAssignment @relation(fields: [crewAssignmentId], references: [id], onDelete: Cascade)
  shootDay         ShootDay       @relation(fields: [shootDayId], references: [id], onDelete: Cascade)

  @@unique([crewAssignmentId, shootDayId])
  @@map("crew_day_calls")
}

// ─── Schedule ─────────────────────────────────────────────────────────────────

model ShootDay {
  id          String   @id @default(cuid())
  projectId   String
  dayNumber   Int
  date        DateTime
  callTime    String?
  wrapTime    String?
  weather     String?
  notes       String?

  project     Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)
  events      ScheduleEvent[]
  crewCalls   CrewDayCall[]

  @@unique([projectId, dayNumber])
  @@map("shoot_days")
}

model ScheduleEvent {
  id           String      @id @default(cuid())
  shootDayId   String
  locationId   String?
  startTime    String      // "7:30 AM"
  endTime      String?     // "9:30 AM"
  title        String
  detail       String?
  isAlert      Boolean     @default(false)
  alertMessage String?

  shootDay     ShootDay        @relation(fields: [shootDayId], references: [id], onDelete: Cascade)
  location     Location?       @relation(fields: [locationId], references: [id])
  tags         EventTag[]
  crewTags     EventCrewTag[]

  @@map("schedule_events")
}

model EventTag {
  id      String         @id @default(cuid())
  eventId String
  type    EventTagType
  label   String?

  event   ScheduleEvent  @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@map("event_tags")
}

enum EventTagType {
  VIDEO
  PHOTO
  AUDIO
  ALL_CREW
  TALENT
  CUSTOM
}

model EventCrewTag {
  id           String        @id @default(cuid())
  eventId      String
  crewMemberId String
  note         String?

  event        ScheduleEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)
  crewMember   CrewMember    @relation(fields: [crewMemberId], references: [id], onDelete: Cascade)

  @@map("event_crew_tags")
}

// ─── Deliverables ─────────────────────────────────────────────────────────────

model Deliverable {
  id            String            @id @default(cuid())
  projectId     String
  title         String
  description   String?
  status        DeliverableStatus @default(WAITING_ON_ASSETS)
  editorName    String?
  aspectRatio   String?
  resolution    String?
  dueDate       String?           // flexible: "7 AM, 5/6" or ISO date
  assetRef      String?           // "Asset #801_"
  musicRef      String?
  isUrgent      Boolean           @default(false)
  notes         String?

  project       Project           @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@map("deliverables")
}

enum DeliverableStatus {
  WAITING_ON_ASSETS
  IN_PROGRESS
  ROUGH_CUT
  IN_REVIEW
  APPROVED
  DELIVERED
}

// ─── Travel — Hotels ──────────────────────────────────────────────────────────

model HotelBlock {
  id        String       @id @default(cuid())
  projectId String
  name      String
  address   String
  phone     String?
  notes     String?

  project   Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  guests    HotelGuest[]

  @@map("hotel_blocks")
}

model HotelGuest {
  id           String     @id @default(cuid())
  hotelBlockId String
  crewMemberId String?
  guestName    String
  confirmation String?
  checkIn      DateTime
  checkOut     DateTime

  hotelBlock   HotelBlock  @relation(fields: [hotelBlockId], references: [id], onDelete: Cascade)
  crewMember   CrewMember? @relation(fields: [crewMemberId], references: [id])

  @@map("hotel_guests")
}

// ─── Travel — Flights ────────────────────────────────────────────────────────

model Flight {
  id           String     @id @default(cuid())
  projectId    String
  crewMemberId String?
  passengerName String
  origin       String
  destination  String
  departTime   DateTime
  arriveTime   DateTime
  airline      String?
  confirmation String?
  isReturn     Boolean    @default(false)

  project      Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  crewMember   CrewMember? @relation(fields: [crewMemberId], references: [id])

  @@map("flights")
}

// ─── Travel — Drive Groups ───────────────────────────────────────────────────

model DriveGroup {
  id          String             @id @default(cuid())
  projectId   String
  origin      String
  destination String
  departTime  DateTime?
  arriveTime  DateTime?
  notes       String?

  project     Project            @relation(fields: [projectId], references: [id], onDelete: Cascade)
  members     DriveGroupMember[]

  @@map("drive_groups")
}

model DriveGroupMember {
  id           String     @id @default(cuid())
  driveGroupId String
  crewMemberId String?
  name         String

  driveGroup   DriveGroup  @relation(fields: [driveGroupId], references: [id], onDelete: Cascade)
  crewMember   CrewMember? @relation(fields: [crewMemberId], references: [id])

  @@map("drive_group_members")
}
